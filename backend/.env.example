PORT=8787
NODE_ENV=development

# Public frontend URL. For GitHub Pages use:
# https://shradaya-raj.github.io
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_APP_PATH=/

# Backend URL. Later this should be your API domain, for example:
# https://api.yourdomain.com
BACKEND_BASE_URL=http://localhost:8787

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# Microsoft Entra app registration
MS_CLIENT_ID=replace-with-azure-app-client-id
MS_CLIENT_SECRET=replace-with-azure-app-client-secret
MS_TENANT_ID=common
MS_REDIRECT_PATH=/api/auth/callback

# Owner OneDrive / SharePoint storage.
# GRAPH_DRIVE_ID is recommended for production. You can discover it with Microsoft Graph Explorer.
GRAPH_DRIVE_ID=
GRAPH_ROOT_FOLDER=GaussianViewer

# Owner notification target shown/used by your workflow.
OWNER_EMAIL=shradaya.poudel@gallimaps.com

# Optional static demo model URL. If empty, frontend static manifest still works.
DEMO_MODEL_URL=
